# Copy to .env.local and fill in (see README).

# Neon — use the pooled connection string for serverless.
DATABASE_URL=

# Upstash Redis (POST rate limit). In development, omit both to skip rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Long random secret for GET /api/admin/waitlist/export (Authorization: Bearer …)
WAITLIST_ADMIN_TOKEN=
